# Copy to .env.local for local dev (never commit .env.local — already gitignored).
# Don't hardcode a value here: the key format/value the Supabase CLI issues can change
# between CLI versions (this bit CI once — see .github/workflows/ci.yml's comment on the
# "Export live local Supabase credentials" step). Always derive it live:
#
#   1. `supabase start` (from apps/web/)
#   2. `supabase status -o env` and copy API_URL -> SUPABASE_URL, SECRET_KEY ->
#      SUPABASE_SERVICE_ROLE_KEY.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
