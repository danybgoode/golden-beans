# Copy to .env.local for local dev (never commit .env.local — already gitignored).
# `supabase start` (from apps/web/) always prints the same well-known local-dev SERVICE_ROLE_KEY
# below for a fresh project — it's a public demo JWT (documented by Supabase), not a secret; the
# same value CI uses. If you've customized supabase/config.toml's JWT secret, run
# `supabase status -o env` and copy SERVICE_ROLE_KEY from there instead.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU
