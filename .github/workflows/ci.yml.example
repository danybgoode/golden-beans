name: CI

# Deterministic pre-merge gate (Roadmap/WAYS-OF-WORKING.md -> Review & merge):
#   typecheck-build  -- your framework's typecheck + build commands, on the PR branch code
#   e2e              -- the `api` Playwright project against the PR's preview (if your deploy rail has one)
#
# TEMPLATE FILL-IN, not a live workflow: this file ships as `ci.yml.example` (not `.yml`) so it does
# NOT run until you rename it AND there's real app code in this project -- otherwise typecheck-build
# fails on a missing package.json and e2e has nothing to test against. Rename to `ci.yml` once your
# app exists, then fill in the two TEMPLATE FILL-IN blocks below for your actual stack + deploy rail.
#
# Deploy rail is a per-project variable (see WAYS-OF-WORKING.md's own note on this) -- the e2e job
# below is written for a preview-per-PR rail (e.g. Vercel). If your deploy rail has NO per-branch
# preview (e.g. Cloud Run on merge-to-main), drop the e2e job entirely and rely on: the api Playwright
# suite run locally / against a dev server pre-merge, plus a post-merge prod smoke as a separate step
# (see WAYS-OF-WORKING.md's QA section for how the origin project splits this).

on:
  pull_request:
    types: [opened, synchronize, reopened]

concurrency:
  group: ci-${{ github.ref }}
  cancel-in-progress: true

jobs:
  typecheck-build:
    name: Type-check + build
    runs-on: ubuntu-latest
    # TEMPLATE FILL-IN: browser-public (publishable) build vars only -- these already ship in the
    # production bundle, so it's safe for them to be plain repo `vars`, not `secrets`. No server
    # secrets belong here if your build doesn't need them for a static/dynamic-safe build (verify
    # locally first). Example shape, not literal names to copy:
    env:
      NEXT_PUBLIC_EXAMPLE_API_URL: ${{ vars.NEXT_PUBLIC_EXAMPLE_API_URL }}
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: 20
          cache: npm
      - run: npm ci --no-audit --no-fund
      - name: Type-check
        run: npx tsc --noEmit
      - name: Build
        run: npm run build

  e2e:
    name: Playwright vs preview
    runs-on: ubuntu-latest
    # TEMPLATE FILL-IN: this job assumes a Vercel-style per-branch preview + a protection-bypass
    # token, as one worked example -- swap for your actual deploy rail's preview mechanism, or delete
    # this job if your rail has no per-branch preview at all.
    env:
      VERCEL_API_TOKEN: ${{ secrets.VERCEL_API_TOKEN }}
      VERCEL_PROJECT_ID: ${{ vars.VERCEL_PROJECT_ID }}
      VERCEL_TEAM_ID: ${{ vars.VERCEL_TEAM_ID }}
      VERCEL_AUTOMATION_BYPASS_SECRET: ${{ secrets.VERCEL_AUTOMATION_BYPASS_SECRET }}
      HEAD_SHA: ${{ github.event.pull_request.head.sha }}
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: 20
          cache: npm
      - run: npm ci --no-audit --no-fund

      - name: Resolve preview URL for this commit
        run: |
          set -euo pipefail
          echo "Waiting for the preview of commit ${HEAD_SHA:0:8}..."
          for i in $(seq 1 40); do
            resp=$(curl -s -H "Authorization: Bearer $VERCEL_API_TOKEN" \
              "https://api.vercel.com/v6/deployments?projectId=$VERCEL_PROJECT_ID&teamId=$VERCEL_TEAM_ID&target=preview&limit=20")
            state=$(echo "$resp" | jq -r --arg s "$HEAD_SHA" \
              'first(.deployments[] | select(.meta.githubCommitSha==$s)) | (.state // .readyState) // ""')
            url=$(echo "$resp" | jq -r --arg s "$HEAD_SHA" \
              'first(.deployments[] | select(.meta.githubCommitSha==$s)) | .url // ""')
            echo "  attempt $i: state=${state:-<none>} url=${url:-<none>}"
            case "$state" in
              READY)
                echo "PLAYWRIGHT_BASE_URL=https://$url" >> "$GITHUB_ENV"
                echo "Preview ready: https://$url"
                exit 0 ;;
              ERROR|CANCELED)
                echo "::error::Preview deployment $state for $HEAD_SHA"; exit 1 ;;
            esac
            sleep 15
          done
          echo "::error::Timed out waiting for the preview of $HEAD_SHA"; exit 1

      - name: Run Playwright suite against the preview
        # PLAYWRIGHT_BASE_URL was exported to $GITHUB_ENV above; a protection-bypass token
        # (wired into playwright.config.ts) reaches an SSO-gated preview, if your rail has one.
        run: npm run test:e2e
